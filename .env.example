# Copier ce fichier en .env (jamais committé, voir .gitignore) et remplir les
# valeurs réelles. Sur Railway : mêmes clés dans Settings > Variables.

# Secret de signature des cookies/JWT d'authentification (fastapi-users).
# Générer une vraie valeur aléatoire avant la mise en prod.
INSTANOTE26_AUTH_SECRET=

# Clé API Brevo (ex-Sendinblue) — Brevo > Settings > SMTP & API > API Keys.
BREVO_API_KEY=

# Adresse expéditeur des emails transactionnels — doit être un expéditeur
# validé dans le compte Brevo (Senders, Domains & Dedicated IPs).
EMAIL_FROM=

# URL de base de l'app, utilisée pour construire les liens dans les emails
# (vérification, réinitialisation de mot de passe).
# Local : http://localhost:8000
# Railway : https://<ton-domaine>.up.railway.app
APP_BASE_URL=
